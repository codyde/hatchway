# Hatchway Web App — environment variables
# Copy to .env.local for local development. In hosted deployments, set these in
# your platform's environment settings.

# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/hatchway

# better-auth session signing secret (generate a long random string)
BETTER_AUTH_SECRET=
# Public URL better-auth issues callbacks/cookies for (e.g. https://app.example.com)
BETTER_AUTH_URL=http://localhost:3000

# Shared secret runners use to authenticate to /ws/runner and runner APIs.
# Must match the runner's RUNNER_SHARED_SECRET. Do NOT use the 'dev-secret'
# default in production.
RUNNER_SHARED_SECRET=

# Encrypts OAuth tokens (GitHub/Railway) at rest. REQUIRED in hosted
# mode — without it, tokens would otherwise be stored in plaintext.
RAILWAY_TOKEN_ENCRYPTION_KEY=

# ─── Sandbox execution mode (Railway sandboxes) ──────────────────────────────
# When a project's execution mode is "Sandbox", the connected local runner builds
# the app locally (using the user's Claude Code) and ships the workspace to an
# ephemeral Railway sandbox the server manages; the sandbox runs the dev server
# and exposes it via railgate. Only needed if you enable Sandbox mode. (No API key
# is required server-side — the local runner uses the user's own Claude Code.)

# Railway API token + environment for the Hatchway project where sandboxes are created.
RAILWAY_API_TOKEN=
RAILWAY_ENVIRONMENT_ID=
# Name of the baked base checkpoint (Node via mise + railgate + tmux + pnpm) that
# every sandbox boots from. Produce it with scripts/bake-sandbox-checkpoint.ts.
SANDBOX_BASE_CHECKPOINT=hatchway-base

# railgate ingress (required for Sandbox previews) — the backend runs the railgate
# client INSIDE the sandbox to expose the dev server at
# https://<subdomain>.<RAILGATE_BASE_DOMAIN>. Set RAILGATE_RELAY_URL to the BASE
# relay URL only (the client appends /_tunnel/connect itself). The baked railgate
# client and the relay must run matching protocol versions.
RAILGATE_RELAY_URL=wss://<relay-subdomain>.<base-domain>
RAILGATE_TOKEN=
RAILGATE_BASE_DOMAIN=portal.hatchway.sh
# Bake-time pin (used by scripts/bake-sandbox-checkpoint.ts):
# SANDBOX_RAILGATE_PACKAGE=railgate@0.6.0

# ─── Operational endpoints ───────────────────────────────────────────────────

# Bearer token gating /api/cleanup, /api/reconcile, /api/processes. These
# expose/mutate cross-tenant state, so they are fail-closed: if OPS_SECRET is
# unset in hosted mode, those endpoints return 401 for everyone. Set this and
# send `Authorization: Bearer <OPS_SECRET>` from cron/automation to enable them.
OPS_SECRET=

# ─── Local development ───────────────────────────────────────────────────────

# When 'true', disables auth/ownership checks and runner auth (single-user dev).
# NEVER set in a shared/hosted deployment.
HATCHWAY_LOCAL_MODE=false

# ─── OAuth integrations (optional) ───────────────────────────────────────────

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
RAILWAY_OAUTH_CLIENT_ID=
RAILWAY_OAUTH_CLIENT_SECRET=

# Validates inbound Railway deployment webhooks (HMAC). Required if you use the
# /api/webhooks/railway endpoint.
RAILWAY_WEBHOOK_SECRET=

# ─── Optional / tuning ───────────────────────────────────────────────────────

# Verify Postgres TLS cert. Set to 'disable' only for local/trusted networks.
# PGSSLMODE=

# Use the WebSocket HTTP proxy for remote preview access instead of tunnels.
# USE_WS_PROXY=false

# Public app URL exposed to the client bundle.
NEXT_PUBLIC_APP_URL=http://localhost:3000

